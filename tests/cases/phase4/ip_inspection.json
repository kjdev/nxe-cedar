                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_multicast_upper_edge",
            "description": "239.255.255.255 is multicast",
            "policy": "permit (principal, action, resource) when { ip(\"239.255.255.255\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
