            },
            "expected": "allow"
        },
        {
            "name": "ipv6_multicast_false",
            "description": "2001:db8::1 is not multicast",
            "policy": "permit (principal, action, resource) when { ip(\"2001:db8::1\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
