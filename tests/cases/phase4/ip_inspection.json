{
    "description": "ip inspection methods: isIpv4, isIpv6, isLoopback, isMulticast",
    "phase": 4,
    "tests": [
        {
            "name": "ipv4_is_ipv4",
            "description": "IPv4 address is IPv4",
            "policy": "permit (principal, action, resource) when { ip(\"10.0.0.1\").isIpv4() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv6_not_ipv4",
            "description": "IPv6 address is not IPv4",
            "policy": "permit (principal, action, resource) when { ip(\"::1\").isIpv4() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv4_cidr_is_ipv4",
            "description": "IPv4 CIDR is IPv4",
            "policy": "permit (principal, action, resource) when { ip(\"10.0.0.0/8\").isIpv4() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv6_is_ipv6",
            "description": "IPv6 address is IPv6",
            "policy": "permit (principal, action, resource) when { ip(\"2001:db8::1\").isIpv6() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_not_ipv6",
            "description": "IPv4 address is not IPv6",
            "policy": "permit (principal, action, resource) when { ip(\"10.0.0.1\").isIpv6() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv6_cidr_is_ipv6",
            "description": "IPv6 CIDR is IPv6",
            "policy": "permit (principal, action, resource) when { ip(\"fe80::/10\").isIpv6() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_loopback_true",
            "description": "127.0.0.1 is loopback",
            "policy": "permit (principal, action, resource) when { ip(\"127.0.0.1\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_loopback_range_edge",
            "description": "127.255.255.255 is loopback",
            "policy": "permit (principal, action, resource) when { ip(\"127.255.255.255\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_loopback_false",
            "description": "10.0.0.1 is not loopback",
            "policy": "permit (principal, action, resource) when { ip(\"10.0.0.1\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv4_loopback_cidr_in_range",
            "description": "127.0.0.0/16 is loopback (entirely within 127.0.0.0/8)",
            "policy": "permit (principal, action, resource) when { ip(\"127.0.0.0/16\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_loopback_cidr_wider",
            "description": "127.0.0.0/7 is not loopback (wider than 127.0.0.0/8)",
            "policy": "permit (principal, action, resource) when { ip(\"127.0.0.0/7\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv6_loopback_true",
            "description": "::1 is loopback",
            "policy": "permit (principal, action, resource) when { ip(\"::1\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv6_loopback_false",
            "description": "::2 is not loopback",
            "policy": "permit (principal, action, resource) when { ip(\"::2\").isLoopback() };",
            "request": {
