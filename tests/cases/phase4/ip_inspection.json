                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"name": "alice"}
            },
            "expected": "deny"
        },
        {
            "name": "is_multicast_non_ip_receiver",
            "description": "isMulticast on non-IP receiver is evaluation error (deny)",
            "policy": "permit (principal, action, resource) when { context.name.isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
