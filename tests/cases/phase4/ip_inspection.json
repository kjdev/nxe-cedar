        {
            "name": "ipv6_multicast_cidr_in_range",
            "description": "ff00::/16 is multicast (within ff00::/8)",
            "policy": "permit (principal, action, resource) when { ip(\"ff00::/16\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "is_ipv4_non_ip_receiver",
            "description": "isIpv4 on non-IP receiver is evaluation error (deny)",
            "policy": "permit (principal, action, resource) when { context.name.isIpv4() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"name": "alice"}
            },
            "expected": "deny"
        },
        {
            "name": "is_loopback_non_ip_receiver",
            "description": "isLoopback on non-IP receiver is evaluation error (deny)",
            "policy": "permit (principal, action, resource) when { context.name.isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"name": "alice"}
            },
            "expected": "deny"
        },
        {
            "name": "context_ip_loopback_permit",
            "description": "use case 8: permit when source ip is loopback",
            "policy": "permit (principal, action, resource) when { context.source_ip.isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"source_ip": {"__extn": {"fn": "ip", "arg": "127.0.0.1"}}}
            },
            "expected": "allow"
        },
        {
            "name": "context_ip_loopback_deny",
            "description": "use case 8: deny when source ip is not loopback",
            "policy": "permit (principal, action, resource) when { context.source_ip.isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"source_ip": {"__extn": {"fn": "ip", "arg": "10.0.0.1"}}}
            },
            "expected": "deny"
        },
        {
            "name": "negated_is_multicast",
            "description": "forbid multicast sources via logical negation",
            "policy": "forbid (principal, action, resource) when { context.source_ip.isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"source_ip": {"__extn": {"fn": "ip", "arg": "224.0.0.1"}}}
            },
            "expected": "deny"
        },
        {
            "name": "combined_ipv4_and_loopback",
            "description": "isIpv4 combined with isLoopback via &&",
            "policy": "permit (principal, action, resource) when { context.source_ip.isIpv4() && context.source_ip.isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"},
                "context": {"source_ip": {"__extn": {"fn": "ip", "arg": "127.0.0.1"}}}
            },
            "expected": "allow"
        },
        {
            "name": "ipv6_loopback_cidr_wider",
            "description": "::1/127 is not loopback (wider than ::1/128)",
            "policy": "permit (principal, action, resource) when { ip(\"::1/127\").isLoopback() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
