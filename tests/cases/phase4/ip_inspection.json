            "policy": "permit (principal, action, resource) when { ip(\"10.0.0.1\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv4_multicast_just_below",
            "description": "223.255.255.255 is not multicast",
            "policy": "permit (principal, action, resource) when { ip(\"223.255.255.255\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv4_multicast_cidr_in_range",
            "description": "224.0.0.0/8 is multicast (within 224.0.0.0/4)",
            "policy": "permit (principal, action, resource) when { ip(\"224.0.0.0/8\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "ipv4_multicast_cidr_wider",
            "description": "224.0.0.0/3 is not multicast (wider than 224.0.0.0/4)",
            "policy": "permit (principal, action, resource) when { ip(\"224.0.0.0/3\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "ipv6_multicast_true",
            "description": "ff00::1 is multicast",
            "policy": "permit (principal, action, resource) when { ip(\"ff00::1\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
