            },
            "expected": "deny"
        },
        {
            "name": "ipv4_multicast_true",
            "description": "224.0.0.1 is multicast",
            "policy": "permit (principal, action, resource) when { ip(\"224.0.0.1\").isMulticast() };",
            "request": {
                "principal": {"type": "User", "id": "alice"},
