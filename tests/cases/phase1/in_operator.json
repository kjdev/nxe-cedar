{
    "description": "in 演算子のテスト",
    "phase": 1,
    "tests": [
        {
            "name": "action_in_set_match",
            "description": "action がセット内に含まれる場合は許可",
            "policy": "permit (principal, action in [Action::\"GET\", Action::\"POST\"], resource);",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        },
        {
            "name": "action_in_set_no_match",
            "description": "action がセット内に含まれない場合は拒否",
            "policy": "permit (principal, action in [Action::\"GET\", Action::\"POST\"], resource);",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "DELETE"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "deny"
        },
        {
            "name": "action_eq_single_entity",
            "description": "action == 単一エンティティ参照",
            "policy": "permit (principal, action == Action::\"GET\", resource);",
            "request": {
                "principal": {"type": "User", "id": "alice"},
                "action": {"type": "Action", "id": "GET"},
                "resource": {"type": "Endpoint", "id": "/api/data"}
            },
            "expected": "allow"
        }
    ]
}
